<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <template id="corehon.layout_pdf" inherit_id="web.report_assets_pdf">
        <xpath expr="." position="inside">
            <link href="/corehon/static/src/css/corehon_style.css" rel="stylesheet"/>
        </xpath>
    </template>

    <template id="corehon.corehon_report_invoice">
        <t t-call="web.html_container">
            <t t-foreach="docs" t-as="o">
                <t t-set="lang" t-value="o.user_id.lang"/>
                <t t-call="corehon.invoice_report_document" t-lang="lang"/>
            </t>
        </t>
    </template>
    <template id="corehon.invoice_report_document">
        <t t-call="corehon.layout_invoice">
        </t>
    </template>
    <template id="corehon.corehon_report_creditnote">
        <t t-call="web.html_container">
            <t t-foreach="docs" t-as="o">
                <t t-set="lang" t-value="o.user_id.lang"/>
                <t t-call="corehon.creditnote_report_document" t-lang="lang"/>
            </t>
        </t>
    </template>
    <template id="corehon.creditnote_report_document">
        <t t-call="corehon.layout_creditnote">
        </t>
    </template>
</odoo>
